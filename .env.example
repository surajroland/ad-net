# ADNet Environment Configuration Example
# Copy this file to .env and customize for your environment

# Docker Build Configuration
VERSION=latest
BUILD_DATE=
VCS_REF=
INSTALL_CUDA=false  # Set to true if you have NVIDIA GPU

# User Configuration - Set these to match your host user
# Run 'id -u' to get your UID and 'id -g' to get your GID
USER_UID=1000
USER_GID=1000

# Service Ports
JUPYTER_PORT=8888
TENSORBOARD_PORT=6006
WANDB_PORT=8097
API_PORT=8000
GRADIO_PORT=7860
VISUALIZATION_PORT=8080

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# API Keys (optional)
GITHUB_TOKEN=
HF_TOKEN=
WANDB_API_KEY=